# -------------------------------------------------------
# Application
# -------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_NAME=VeriTix Backend

# -------------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=veritix_db
DATABASE_SSL=false

# -------------------------------------------------------
# Auth — JWT secrets MUST be at least 32 characters
# -------------------------------------------------------
ACCESS_TOKEN_SECRET=change_me_to_a_random_32_plus_char_secret
REFRESH_TOKEN_SECRET=change_me_to_another_random_32_plus_char_secret
ACCESS_TOKEN_EXPIRATION=1h
REFRESH_TOKEN_EXPIRATION=7d

# -------------------------------------------------------
# CORS — comma-separated list of allowed origins
# Leave blank to allow all origins (not recommended for production)
# -------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------
# SendGrid — email delivery
# -------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@veritix.io

# -------------------------------------------------------
# Stellar blockchain integration
# -------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_RECEIVING_ADDRESS=
STELLAR_PLATFORM_ADDRESS=
STELLAR_SECRET_KEY=

# -------------------------------------------------------
# Orders
# -------------------------------------------------------
ORDER_EXPIRY_MINUTES=15
