# Runtime
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veritix
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veritix_test

# Auth
ACCESS_TOKEN_SECRET=replace-with-a-32-character-minimum-secret
REFRESH_TOKEN_SECRET=replace-with-a-32-character-minimum-secret
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# Orders
ORDER_EXPIRY_MINUTES=15

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RECEIVING_ADDRESS=
STELLAR_SECRET_KEY=
STELLAR_WEBHOOK_SECRET=replace-with-a-32-character-minimum-webhook-secret

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@veritix.com

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# Storage
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
